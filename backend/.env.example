# Backend Environment Variables for Production (Render)
# Copy to .env and fill in your values

MONGODB_URI=your_mongodb_connection_string
AZURE_CLIENT_ID=your_azure_app_client_id
AZURE_TENANT_ID=your_tenant_id_or_common
MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret
SESSION_SECRET=your_session_secret_key
JWT_SECRET=your_jwt_secret

# Production URLs - CRITICAL for OAuth callback
BACKEND_URL=https://university-event-club-management-system.onrender.com
FRONTEND_URLS=https://university-event-club-management-sy.vercel.app/,https://university-event-club-management-sy.vercel.app

# Development overrides (uncomment for local)
# BACKEND_URL=http://localhost:5000
# FRONTEND_URLS=http://localhost:3000
