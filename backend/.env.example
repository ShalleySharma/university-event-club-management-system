# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/campus_connect

# JWT Secret (change this to a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-this
SESSION_SECRET=your-session-secret-change-this

# Frontend URL
FRONTEND_URL=http://localhost:3000

# ============================================
# MICROSOFT AZURE AD CONFIGURATION
# ============================================
# You need to register an app in Azure Active Directory:
# 1. Go to https://portal.azure.com/
# 2. Go to Azure Active Directory > App registrations
# 3. Create a new app registration
# 4. Get the Application (client) ID
# 5. Go to "Certificates & secrets" to create a client secret
# 6. Go to "Authentication" > Add platform > Web
#    - Redirect URI: http://localhost:5000/api/auth/microsoft/callback
# 7. Go to "API permissions" > Add permission > Microsoft Graph
#    - Delegated permissions: User.Read, openid, profile, email

# Azure AD Client ID
AZURE_CLIENT_ID=your-azure-client-id

# Azure AD Client Secret
MICROSOFT_CLIENT_SECRET=your-azure-client-secret

# Azure AD Tenant ID (use "common" for multi-tenant or your specific tenant ID)
AZURE_TENANT_ID=common

# Callback URL (optional - can be hardcoded in passport.js)
MICROSOFT_CALLBACK_URL=http://localhost:5000/api/auth/microsoft/callback

